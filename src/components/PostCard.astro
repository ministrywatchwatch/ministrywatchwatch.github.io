---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  mode: string;
  recommendation: string;
  series?: { name: string; episode: number };
}

const { title, description, pubDate, slug, mode, recommendation, series } = Astro.props;

const modeLabel: Record<string, string> = {
  overreaction: 'OVERREACTION ALERT',
  extrapolation: 'EXTRAPOLATED ANALYSIS',
  hallucinatory: 'ALLEGEDLY REPORTING',
};

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<article class="post-card">
  <div class="card-meta">
    <span class="mode-tag">{modeLabel[mode] ?? mode.toUpperCase()}</span>
    {series && (
      <span class="series-tag">{series.name.toUpperCase()} · PART {series.episode}</span>
    )}
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
  </div>
  <h2><a href={`/posts/${slug}`}>{title}</a></h2>
  <p class="description">{description}</p>
  <div class="card-footer">
    <span class="rec-pill">{recommendation}</span>
    <a href={`/posts/${slug}`} class="read-more">Read Full Assessment →</a>
  </div>
</article>

<style>
  .post-card {
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-navy);
    padding: 1.5rem;
    background: white;
    margin-bottom: 1.5rem;
  }

  .card-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .mode-tag {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    background: var(--color-navy);
    color: white;
    padding: 0.2rem 0.5rem;
  }

  .series-tag {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    background: var(--color-gold);
    color: var(--color-navy);
    padding: 0.2rem 0.5rem;
  }

  time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  h2 a {
    text-decoration: none;
    color: var(--color-text);
  }

  h2 a:hover {
    color: var(--color-navy);
  }

  .description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .rec-pill {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold);
    border: 1px solid var(--color-gold);
    padding: 0.15rem 0.4rem;
  }

  .read-more {
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
  }
</style>
